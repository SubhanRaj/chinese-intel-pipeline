{
	"name": "dashboard",
	"main": ".open-next/worker.js",
	"compatibility_date": "2026-06-23",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "intel_briefings_db",
			"database_id": "d48e8453-eb7e-4c39-8c54-973433bb9d92"
		}
	]
}
